<?xml version="1.0" encoding="utf-8"?>
<!--
  Tells Android — and Samsung Smart Switch / device-to-device transfer —
  not to copy any of the app's data when the user reinstalls or moves
  to a new phone. Without this, SharedPreferences (including the
  onboarding-complete flag) gets restored and the tutorial gets skipped
  on what is supposed to be a fresh install.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </device-transfer>
</data-extraction-rules>
